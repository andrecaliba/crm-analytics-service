# =============================================================================
# crm-analytics-service - environment variables
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# -- FastAPI / uvicorn --------------------------------------------------------
# Must match the CRM service DATABASE_URL exactly - both share the same DB.
# Use localhost here - uvicorn runs natively, not inside Docker.
DATABASE_URL=postgresql://user:password@localhost:5433/db-name

# Same secret the CRM login endpoint uses to sign JWTs.
# This service only verifies tokens, never issues them.
JWT_SECRET=your-jwt-secret-here


# -- Apache Airflow 3.x (docker-compose.airflow.yml) --------------------------
# Airflow stores its metadata (DAG runs, task history, etc.) in a dedicated
# "airflow" schema within the same PostgreSQL database.
#
# IMPORTANT: Use host.docker.internal here (not localhost) - Airflow runs
# inside Docker and needs to reach your machine's Postgres through the host.
#
# Formula: same user/pass/db as DATABASE_URL, host -> host.docker.internal,
#          append ?options=-csearch_path%3Dairflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql://user:password@host.docker.internal:5433/db-name?options=-csearch_path%3Dairflow

# Airflow web UI credentials - change before sharing with anyone.
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=changeme
