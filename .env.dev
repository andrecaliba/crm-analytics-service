# =============================================================================
# Shared dev environment for cross-service testing
# Copy this to .env when running locally.
#
# Uses the same Postgres instance as project-sales-crm (port 5432).
# JWT_SECRET is intentionally omitted — both services fall back to the same
# default value ("change-me-to-a-32-char-random-string") defined in:
#   - CRM:       lib/auth.ts
#   - Analytics:  auth.py
#
# In production (Railway), set JWT_SECRET explicitly in both services.
# =============================================================================

DATABASE_URL=postgresql://zeandycontrolflowlabs.com@localhost:5432/sales_crm_dev
